rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "oalbogdady1@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isTaskOwner(taskId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/tasks/$(taskId)) &&
             get(/databases/$(database)/documents/tasks/$(taskId)).data.userId == request.auth.uid;
    }

    // Validation Helpers
    function isValidString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    function isValidTask(data) {
      let allowedFields = ['userId', 'title', 'type', 'status', 'progress', 'createdAt', 'description', 'dueDate', 'calendarEventId', 'recurrence', 'parentId'];
      return allowedFields.hasAll(data.keys()) &&
             data.userId == request.auth.uid &&
             isValidString(data.title, 100) &&
             data.type in ['assignment', 'exam'] &&
             data.status in ['pending', 'completed'] &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.createdAt is timestamp &&
             (!('dueDate' in data) || data.dueDate is timestamp) &&
             (!('description' in data) || data.description is string && data.description.size() <= 1000) &&
             (!('calendarEventId' in data) || data.calendarEventId is string) &&
             (!('recurrence' in data) || data.recurrence in ['daily', 'weekly', 'monthly', 'none']) &&
             (!('parentId' in data) || data.parentId is string);
    }

    function isValidSubTask(data) {
      let allowedFields = ['taskId', 'title', 'completed', 'order'];
      return allowedFields.hasAll(data.keys()) &&
             isValidString(data.title, 200) &&
             data.completed is bool &&
             data.order is number;
    }

    function isValidNote(data) {
      let allowedFields = ['taskId', 'content', 'type', 'question', 'answer', 'hint'];
      return allowedFields.hasAll(data.keys()) && 
             data.type in ['concept', 'flashcard'] &&
             (data.type == 'concept' ? (
               isValidString(data.content, 5000) && 
               !('question' in data) && !('answer' in data) && !('hint' in data)
             ) : (
               isValidString(data.question, 1000) && 
               isValidString(data.answer, 1000) && 
               (!('hint' in data) || data.hint is string && data.hint.size() <= 500) &&
               !('content' in data)
             ));
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'email', 'displayName', 'photoURL', 'calendarSyncEnabled', 'aiEnabled', 'hasCompletedOnboarding', 'themeColor'];
      return data.keys().hasAll(['uid', 'email']) &&
             allowedFields.hasAll(data.keys()) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 255 &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('calendarSyncEnabled' in data) || data.calendarSyncEnabled is bool) &&
             (!('aiEnabled' in data) || data.aiEnabled is bool) &&
             (!('hasCompletedOnboarding' in data) || data.hasCompletedOnboarding is bool) &&
             (!('themeColor' in data) || data.themeColor is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin()) &&
        isValidTask(request.resource.data) &&
        request.resource.data.createdAt == resource.data.createdAt; // Immutable field
        
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      // Sub-tasks
      match /subtasks/{subtaskId} {
        allow read: if isTaskOwner(taskId) || isAdmin();
        allow create: if isTaskOwner(taskId) && isValidSubTask(request.resource.data);
        allow update: if isTaskOwner(taskId) && isValidSubTask(request.resource.data);
        allow delete: if isTaskOwner(taskId) || isAdmin();
      }

      // Notes
      match /notes/{noteId} {
        allow read: if isTaskOwner(taskId) || isAdmin();
        allow create: if isTaskOwner(taskId) && isValidNote(request.resource.data);
        allow update: if isTaskOwner(taskId) && isValidNote(request.resource.data);
        allow delete: if isTaskOwner(taskId) || isAdmin();
      }
    }
  }
}
